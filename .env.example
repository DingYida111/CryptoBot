# ============================================================
# OKX API Configuration
# For Phase 1 (data collection), only market data endpoint
# is needed. No trading permissions required.
# ============================================================
OKX_API_KEY=your_okx_api_key
OKX_API_SECRET=your_okx_api_secret
OKX_API_PASSPHRASE=your_okx_api_passphrase
OKX_USE_PROXY=false

# ============================================================
# Polymarket Configuration
# Uses public CLOB API - no authentication required
# ============================================================
POLYMARKET_PRIVATE_KEY=your_wallet_private_key
SIG_TYPE=eoa
PROXY_WALLET_ADDRESS=
CHAIN_ID=137

# ============================================================
# Data Collection Settings
# ============================================================
DATA_COLLECT_INTERVAL_MS=5000
TARGET_MARKETS=btc
WINDOW_DURATION_MINUTES=15

# ============================================================
# Logging
# ============================================================
LOG_DIR=logs
LOG_FILE_PREFIX=collector
DEBUG=false

# ============================================================
# Strategy & Friction Settings
# ============================================================
# Signal threshold: Polymarket upBid must exceed this to trigger a signal
SIGNAL_THRESHOLD=0.55

# Polymarket taker fee rate (as decimal, e.g. 0.02 = 2%)
POLYMARKET_FEE_RATE=0.02

# A/B test variant: control | regime_filtered | momentum
# See src/strategy/ab_test.ts for variant definitions
STRATEGY_VARIANT=control

# ============================================================
# CHOP Grid Settings
# Long-inventory grid used only in CHOP / RANGE regimes
# ============================================================
CHOP_GRID_LAYERS=3
CHOP_GRID_SPACING_PCT=0.006
CHOP_GRID_ORDER_SIZE=1
CHOP_GRID_SEED_MULTIPLIER=3
CHOP_GRID_MAX_INVENTORY=9
CHOP_GRID_RECENTER_PCT=0.012
CHOP_GRID_BREAKOUT_PCT=0.025
CHOP_GRID_COOLDOWN_MS=60000
