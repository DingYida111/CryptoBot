{
  "name": "cryptobot",
  "version": "0.1.0",
  "description": "Polymarket signal-driven OKX BTC futures trading bot",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "collect": "tsx src/monitor/run.ts",
    "collect:dist": "node dist/monitor/run.js",
    "benchmark:okx-grid": "tsx src/runtime/run_okx_grid_benchmark.ts",
    "supervisor:strategies": "tsx src/runtime/run_strategy_supervisor.ts",
    "supervisor:strategies:dist": "node dist/runtime/run_strategy_supervisor.js",
    "test:portfolio": "node --import tsx --test src/portfolio/**/*.test.ts",
    "test:carry": "node --import tsx --test src/carry/**/*.test.ts",
    "test:runtime": "node --import tsx --test src/runtime/**/*.test.ts",
    "report:portfolio-shadow": "node --import tsx src/portfolio/run_shadow_report.ts",
    "report:runtime-traces": "node --import tsx src/portfolio/run_runtime_trace_report.ts",
    "report:runtime-actions": "node --import tsx src/runtime/run_runtime_action_report.ts",
    "report:runtime-control": "node --import tsx src/runtime/run_runtime_control_report.ts",
    "report:funding-arb": "node --import tsx src/runtime/run_funding_arb_report.ts",
    "run:runtime-message-self-test": "node --import tsx src/runtime/run_runtime_message_self_test.ts",
    "run:runtime-trace-fixture": "node --import tsx src/runtime/run_runtime_trace_fixture.ts",
    "run:runtime-action-executor": "node --import tsx src/runtime/run_runtime_action_executor.ts",
    "run:runtime-heartbeat": "node dist/runtime/run_runtime_heartbeat.js",
    "run:pm2-heartbeat-proxy": "node dist/runtime/run_pm2_heartbeat_proxy.js",
    "run:runtime-maintenance-lease": "node dist/runtime/run_runtime_maintenance_lease.js",
    "run:runtime-watchdog": "node dist/runtime/run_runtime_watchdog.js",
    "run:runtime-disconnect-dry-run": "node dist/runtime/run_runtime_disconnect_dry_run.js",
    "run:okx-connectivity": "node --import tsx src/runtime/run_okx_connectivity_check.ts",
    "run:funding-arb:validate": "node --import tsx src/runtime/run_funding_arbitrage_validation.ts",
    "run:okx-batch-funding-validate": "node --import tsx src/trade/run_okx_batch_funding_pair_validation.ts",
    "run:okx-batch-funding-watch": "node --import tsx src/trade/run_okx_batch_funding_pair_watcher.ts",
    "run:okx-batch-funding-watch:dist": "node dist/trade/run_okx_batch_funding_pair_watcher.js",
    "run:chop-grid-pnl-reconcile": "node dist/trade/run_chop_grid_pnl_reconcile.js",
    "deploy:release": "bash scripts/deploy_release.sh",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": ["polymarket", "okx", "trading-bot", "bitcoin", "quant"],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.6.0 <23"
  }
}
